          "name": "PUT /booking/{id} - no auth token (negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 403 Forbidden without auth', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Hacker\",\n  \"lastname\": \"Doe\",\n  \"totalprice\": 200,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-08-01\",\n    \"checkout\": \"2026-08-05\"\n  },\n  \"additionalneeds\": \"None\"\n}"
            },
            "url": { "raw": "{{base_url}}/booking/{{booking_id}}", "host": ["{{base_url}}"], "path": ["booking", "{{booking_id}}"] }
          }
        }
